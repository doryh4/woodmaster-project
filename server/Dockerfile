# 1. משתמשים באימג' רשמי של Node.js כבסיס
FROM node:18-alpine

# 2. מגדירים את תיקיית העבודה בתוך הקונטיינר
WORKDIR /usr/src/app

# 3. מעתיקים את קבצי ניהול החבילות כדי להתקין תלויות
COPY package*.json ./

# 4. מתקינים את כל התלויות (כולל devDependencies שדרושות לקומפילציה)
RUN npm install

# 5. מעתיקים את כל שאר קבצי השרת לתוך הקונטיינר
COPY . .

# 6. חושפים את הפורט שהשרת מאזין לו (הגדרת ברירת המחדל שלך היא 5000)
EXPOSE 5000

# 7. פקודת ההרצה של השרת במצב פיתוח/הרצה עם ts-node
CMD ["npm", "start"]